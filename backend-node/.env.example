PORT=3001

# MongoDB Atlas connection (replace with your Atlas URI)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/vedaai?retryWrites=true&w=majority&appName=Cluster0

# Redis (local Docker: docker run -d -p 6379:6379 redis:alpine)
REDIS_URL=redis://localhost:6379

# AI keys — at least one required
# Primary: HuggingFace (free tier, use Mixtral-8x7B)
HF_API_TOKEN=hf_your_token_here

# Optional fallback: Google Gemini
GEMINI_API_KEY=

FRONTEND_URL=http://localhost:3000
UPLOAD_DIR=uploads
